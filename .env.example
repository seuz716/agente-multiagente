# Configuración de Agente Multiagente
# Copia este archivo a .env y ajusta los valores

# ========================================
# CONFIGURACIÓN DEL SERVIDOR NODE.JS
# ========================================

# Puerto del servidor (default: 3000)
AGENTE_PORT=3000

# API Key para autenticación (¡cámbiala en producción!)
AGENTE_API_KEY=tu_api_key_super_segura_123

# Nivel de logging (debug, info, warn, error)
LOG_LEVEL=info

# ========================================
# CONFIGURACIÓN DEL CLIENTE DJANGO
# ========================================

# URL del servidor agente
AGENTE_URL=http://localhost:3000

# Timeout para requests en segundos
AGENTE_TIMEOUT=30

# Máximo de reintentos
AGENTE_MAX_RETRIES=3

# Delay entre reintentos (exponential backoff)
AGENTE_RETRY_DELAY=1

# API Key para autenticación contra el agente
AGENTE_API_KEY=tu_api_key_super_segura_123